# Turso 데이터베이스 설정
# 원격 Turso DB 사용 시:
#   1) turso db create ysettlement
#   2) turso db show ysettlement --url        -> TURSO_DATABASE_URL
#   3) turso db tokens create ysettlement     -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# 로컬 개발용(Turso 계정 없이 파일 DB)으로 쓰려면 아래처럼 설정:
# TURSO_DATABASE_URL=file:local.db
# TURSO_AUTH_TOKEN=

# 네이버 지도(NCP) Maps API — 유류비/통행료 자동 계산용
#   ※ 2025년 콘솔 이전: 구 "AI·NAVER API" 가 아니라 신규 "Maps" 제품에서 등록.
#   NCP 콘솔 > Services > Application Services > Maps 에서 이용신청 후
#   Application 에 Geocoding + Directions 5 를 선택하고 Client ID/Secret 발급.
#   기본 도메인: https://maps.apigw.ntruss.com
NCP_MAPS_KEY_ID=your-client-id
NCP_MAPS_KEY=your-client-secret
# (선택) 구 도메인을 써야 하면 override:
# NCP_MAPS_BASE_URL=https://naveropenapi.apigw.ntruss.com

# 네이버 지역검색(Local Search) API — "장소명"으로 검색하려면 필요 (예: 의왕호수공원)
#   ※ NCP 가 아니라 네이버 개발자센터(https://developers.naver.com) 에서
#     애플리케이션 등록 > "검색" API 추가 후 발급되는 별도 키입니다.
#   없으면 주소 검색만 동작합니다.
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
