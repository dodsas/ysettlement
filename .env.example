# Turso 데이터베이스 설정
# 원격 Turso DB 사용 시:
#   1) turso db create ysettlement
#   2) turso db show ysettlement --url        -> TURSO_DATABASE_URL
#   3) turso db tokens create ysettlement     -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# 로컬 개발용(Turso 계정 없이 파일 DB)으로 쓰려면 아래처럼 설정:
# TURSO_DATABASE_URL=file:local.db
# TURSO_AUTH_TOKEN=
